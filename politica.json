{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowS3ActionsOnBuyMaxBucket",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::buymax-multimedia-prod-001",
                "arn:aws:s3:::buymax-multimedia-prod-001/*"
            ]
        },
        {
            "Sid": "AllowS3ListingForApp",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": "arn:aws:s3:::buymax-multimedia-prod-001"
        }
    ]
}
